const failedActionCountsRef = useRef<Record<string, number>>({});

const validateDecision = (
 best: ReturnType<typeof selectBestTimelineEvent>
): DecisionValidation => {
 if (!best) {
   return {
     verdict: "review",
     allowed: false,
     confidence: 0.2,
     reason: "No candidate exists.",
     checks: [
       { name: "candidate_exists", passed: false, reason: "Timeline is empty." },
     ],
   };
 }

 const payload = best.item?.payload;
 const score = best.score;
 const spiral = payload?.section?.spiral_snapshot || payload?.spiral_state || latestSpiralState;

 const focus = Number(spiral?.focus ?? 0.5);
 const convergence = Number(spiral?.goal_convergence ?? 0.4);
 const confidence = Number(spiral?.confidence ?? 0.5);
 const instability = 1 - ((focus + convergence + confidence) / 3);

 const priorFailures = failedActionCountsRef.current[best.item.type] ?? 0;
 const autonomousAllowed = autonomousMode;
 const dryRunSafe = dryRun || payload?.dry_run === true || true;

 const checks: ValidationCheck[] = [
   {
     name: "quality_gate",
     passed: score >= qualityThreshold,
     reason:
       score >= qualityThreshold
         ? `Score ${score.toFixed(2)} passed threshold ${qualityThreshold.toFixed(2)}.`
         : `Score ${score.toFixed(2)} below threshold ${qualityThreshold.toFixed(2)}.`,
     score,
   },
   {
     name: "stability_gate",
     passed: instability <= 0.42,
     reason:
       instability <= 0.42
         ? `Instability ${instability.toFixed(2)} within range.`
         : `Instability ${instability.toFixed(2)} too high.`,
     score: 1 - instability,
   },
   {
     name: "failure_pattern_gate",
     passed: priorFailures < 3,
     reason:
       priorFailures < 3
         ? `Prior failures acceptable (${priorFailures}).`
         : `Action pattern has failed too often (${priorFailures}).`,
   },
   {
     name: "authority_gate",
     passed: autonomousAllowed,
     reason: autonomousAllowed
       ? "Autonomous authority enabled."
       : "Autonomous authority disabled.",
   },
   {
     name: "safe_execution_gate",
     passed: dryRunSafe,
     reason: dryRunSafe
       ? "Safe execution path available."
       : "Unsafe execution path detected.",
   },
 ];

 const failed = checks.filter((c) => !c.passed);

 if (failed.length === 0) {
   return {
     verdict: "allow",
     allowed: true,
     confidence: score,
     reason: "Decision passed validation.",
     checks,
   };
 }

 const hardBlock = failed.some(
   (c) =>
     c.name === "authority_gate" ||
     c.name === "failure_pattern_gate" ||
     c.name === "stability_gate"
 );

 return {
   verdict: hardBlock ? "block" : "review",
   allowed: false,
   confidence: Math.max(0.1, score * 0.8),
   reason: hardBlock
     ? `Blocked by ${failed.map((c) => c.name).join(", ")}.`
     : `Review required due to ${failed.map((c) => c.name).join(", ")}.`,
   checks,
 };
};
