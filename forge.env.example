FORGE_PROVIDER_MODE=custom
FORGE_API_URL=http://127.0.0.1:8001/v1/chat/completions
FORGE_VISION_API_URL=http://127.0.0.1:8002/v1/chat/completions
FORGE_API_KEY=
FORGE_MODEL=my-local-model
FORGE_FAST_MODEL=my-local-model-fast
FORGE_QUALITY_MODEL=my-local-model-quality
FORGE_VISION_MODEL=my-local-model-vision
GENERAL_MODEL=gemma3:12b
CODING_MODEL=devstral
LIGHT_CODING_MODEL=qwen2.5-coder:7b
FORGE_MODEL_SWITCH_MODE=auto
FORGE_MODEL_SWITCH_PINNED_SYSTEM=
FORGE_HOST=127.0.0.1
FORGE_PORT=8080
FORGE_TIMEOUT_SECONDS=40
FORGE_EXECUTION_TIMEOUT_SECONDS=15
FORGE_EXECUTION_MAX_CODE_CHARS=12000
FORGE_EXECUTION_MAX_OUTPUT_CHARS=16000
FORGE_EXECUTION_MAX_FILES=2048
FORGE_EXECUTION_MAX_FILE_BYTES=1048576
FORGE_EXECUTION_BACKEND=auto
FORGE_DOCKER_IMAGE=python:3.11-alpine
FORGE_DOCKER_MEMORY=256m
FORGE_DOCKER_CPUS=1.0
FORGE_DOCKER_PIDS_LIMIT=64
FORGE_DOCKER_WORKDIR=/workspace
FORGE_DOCKER_TMPFS_SIZE=64m
FORGE_DOCKER_NETWORK_DISABLED=true
FORGE_DOCKER_READ_ONLY_ROOT=true
FORGE_DOCKER_NO_NEW_PRIVILEGES=true
FORGE_DOCKER_USER=
FORGE_COMMAND_TIMEOUT_SECONDS=60
FORGE_ALLOWED_COMMANDS=python,python3,pytest,pip,pip3,uv,git,ls,pwd,cat,head,tail,find,grep,wc,echo
FORGE_AGENT_MAX_COMMAND_TIER=read_only
FORGE_AGENT_ALLOW_PYTHON=true
FORGE_AGENT_ALLOW_SHELL=true
FORGE_AGENT_ALLOW_FILESYSTEM_READ=true
FORGE_AGENT_ALLOW_FILESYSTEM_WRITE=true
FORGE_REPO_UPLOAD_MAX_BYTES=12000000
FORGE_REPO_ARCHIVE_MAX_ENTRIES=2048
FORGE_REPO_MAX_TOTAL_BYTES=48000000
FORGE_REPO_CLONE_TIMEOUT_SECONDS=180
FORGE_REPO_ALLOWED_CLONE_HOSTS=github.com,gitlab.com,bitbucket.org
FORGE_WORKSPACE_SEARCH_MAX_RESULTS=25
FORGE_WORKSPACE_SEARCH_MAX_EXCERPT_CHARS=220
FORGE_WORKSPACE_SNAPSHOT_MAX_ENTRIES=4096
FORGE_WORKSPACE_SNAPSHOT_MAX_TOTAL_BYTES=64000000
FORGE_WORKSPACE_SNAPSHOT_MAX_SNAPSHOTS=20
FORGE_CACHE_SIZE=64
FORGE_MAX_CONTEXT_MESSAGES=10
FORGE_MAX_RESPONSE_TOKENS=900
FORGE_RETRIEVAL_K=4
FORGE_FAST_MODE_DEFAULT=true
FORGE_ENABLE_REMOTE_FETCH=true
FORGE_AGENT_RUN_DB_PATH=.forge_chat/agent-runs.db
FORGE_APPROVAL_DB_PATH=.forge_chat/approvals.db
FORGE_AGENT_WORKER_ENABLED=true
FORGE_AGENT_WORKER_CONCURRENCY=1
FORGE_AGENT_WORKER_POLL_SECONDS=0.1
FORGE_AGENT_WORKER_LEASE_SECONDS=30
FORGE_AGENT_WORKER_HEARTBEAT_SECONDS=5
FORGE_AGENT_WORKER_MAX_ATTEMPTS=3
FORGE_AGENT_WORKER_RETRY_DELAY_SECONDS=2
FORGE_WORKSPACES_DIR=.forge_chat/workspaces
